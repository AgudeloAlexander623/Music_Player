# ===========================================
# REPRODUCTOR DE MÚSICA - CONFIGURACIÓN
# ===========================================
# Este archivo contiene las variables de entorno necesarias
# para el funcionamiento del proyecto.
#
# PASOS PARA CONFIGURAR:
# 1. Copia este archivo como .env
# 2. Reemplaza los valores de ejemplo con tus credenciales reales
# 3. Nunca subas el archivo .env al repositorio (ya está en .gitignore)

# ===========================================
# SPOTIFY WEB API CONFIGURATION
# ===========================================
# Obtén estas credenciales desde: https://developer.spotify.com/dashboard
# 1. Crea una aplicación en Spotify Developer Dashboard
# 2. Ve a Settings > Basic Information
# 3. Copia Client ID y Client Secret

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Puerto donde correrá el servidor backend
# Default: 4000 (si no se especifica)
PORT=4000

# ===========================================
# DATABASE CONFIGURATION (MySQL)
# ===========================================
# Configuración para la base de datos MySQL
# IMPORTANTE: La base de datos debe existir antes de iniciar el servidor

DB_HOST=localhost
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password
DB_NAME=reproductor_db

# ===========================================
# JWT CONFIGURATION
# ===========================================
# Clave secreta para firmar tokens JWT
# IMPORTANTE: Usa una clave segura y única para producción
# Genera una con: openssl rand -base64 32

JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ===========================================
# DEVELOPMENT NOTES
# ===========================================
# - Para desarrollo local, usa localhost para DB_HOST
# - Para producción, configura las variables según tu proveedor
# - Mantén JWT_SECRET seguro y no lo compartas
# - Las credenciales de Spotify tienen límites de rate limit