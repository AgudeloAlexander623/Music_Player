# ===========================================
#  REPRODUCTOR — FRONTEND (dev, hot-reload)
# ===========================================
#  Contenedor liviano solo para desarrollo.
#  Usa Vite en modo servidor de desarrollo con
#  hot-reload.  El código se monta como volumen
#  desde el host (ver docker-compose.dev.yml).
# ===========================================

FROM node:20-alpine

WORKDIR /app

COPY package*.json ./

RUN npm install

COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host"]
