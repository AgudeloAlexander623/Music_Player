FROM node:20-alpine AS base

WORKDIR /app

COPY package*.json ./

ARG NODE_ENV=production
ENV NODE_ENV=${NODE_ENV}

RUN if [ "$NODE_ENV" = "production" ]; then \
      npm ci --only=production && npm cache clean --force; \
    else \
      npm ci && npm cache clean --force; \
    fi

COPY . .

EXPOSE 4000

USER node

CMD ["node", "src/app.js"]
