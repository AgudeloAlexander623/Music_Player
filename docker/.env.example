# ===========================================
# REPRODUCTOR - DOCKER ENVIRONMENT VARIABLES
# ===========================================
# Copia este archivo como .env en la raiz del proyecto
# cp docker/.env.example .env

# ===========================================
# DATABASE
# ===========================================
MYSQL_ROOT_PASSWORD=rootpassword
DB_USER=reproductor_user
DB_PASSWORD=reproductor_pass
DB_NAME=reproductor_db
DB_PORT=3306

# ===========================================
# SPOTIFY
# ===========================================
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ===========================================
# FREE MUSIC ARCHIVE
# ===========================================
FMA_API_KEY=your_fma_api_key

# ===========================================
# JWT
# ===========================================
JWT_SECRET=your_super_secret_jwt_key_change_this

# ===========================================
# PORTS
# ===========================================
BACKEND_PORT=4000
FRONTEND_PORT=5173
PYTHON_PORT=8000
