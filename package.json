{
  "name": "reproductor-musica",
  "version": "1.0.0-beta",
  "description": "Spotify-inspired music app - educational project",
  "private": true,
  "scripts": {
    "install:all": "cd BackEnd && npm install && cd ../FrontEnd/mi-app && npm install",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd BackEnd && npm run dev",
    "dev:frontend": "cd FrontEnd/mi-app && npm run dev",
    "build:frontend": "cd FrontEnd/mi-app && npm run build",
    "test:backend": "cd BackEnd && npm test",
    "test:frontend": "cd FrontEnd/mi-app && npm test",
    "docker:dev": "docker compose --env-file .env -f docker/docker-compose.dev.yml up -d --build",
    "docker:prod": "docker compose --env-file .env -f docker/docker-compose.yml up -d --build",
    "docker:down": "docker compose --env-file .env -f docker/docker-compose.yml down",
    "docker:logs": "docker compose --env-file .env -f docker/docker-compose.yml logs -f",
    "docker:dev:logs": "docker compose --env-file .env -f docker/docker-compose.dev.yml logs -f"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
